  },

  "auswertung": {
    "vergleich_mit_B": "Identische item-IDs → direkte Differenzbildung pro Item: B-E[item] – B[item]",
    "konstrukt_score": "Mittelwert der likert4-Items je Konstrukt — wie Bogen B",
    "interpretation": "Positive Differenz: Leitung überschätzt Teilnehmer*innen. Negative Differenz: Leitung unterschätzt."
  }
