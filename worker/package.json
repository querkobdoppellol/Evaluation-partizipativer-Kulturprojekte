{
  "name": "wertapp-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply wertapp --local",
    "db:migrate:remote": "wrangler d1 migrations apply wertapp --remote",
    "db:seed:local": "wrangler d1 execute wertapp --local --file=migrations/seed.sql",
    "db:seed:remote": "wrangler d1 execute wertapp --remote --file=migrations/seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.101.0"
  }
}
